generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  user_id    Int      @id @default(autoincrement())
  name       String
  username   String   @unique
  birth_date DateTime
  place_of_birth String
  profession String
  email      String   @unique
  password   String
  created_at DateTime @default(now())
}

model visitors {
  visitor_id Int      @id @default(autoincrement())
  token      String   @unique
  created_at DateTime @default(now())
  expires_at DateTime
}

model post {
  post_id    Int      @id @default(autoincrement())
  title      String
  content    String
  post_image String?
  user_id    Int
  created_at DateTime @default(now())

  @@index([user_id])
}

model reactions {
  reaction_id Int      @id @default(autoincrement())
  type        String
  user_id     Int
  visitor_id  Int?
  post_id     Int
  created_at  DateTime @default(now())

  @@index([user_id])
  @@index([visitor_id])
  @@index([post_id])
}

model comments {
  comment_id   Int      @id @default(autoincrement())
  content      String
  user_id      Int
  visitor_id   Int?
  post_id      Int
  created_at   DateTime @default(now())
  is_moderated Boolean  @default(false)

  @@index([user_id])
  @@index([visitor_id])
  @@index([post_id])
}
